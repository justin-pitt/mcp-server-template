# Transport: stdio (engineer mode, default) or http (platform mode)
MCP_TRANSPORT=stdio
# Port for HTTP transport. Only used when MCP_TRANSPORT=http.
MCP_PORT=8080
# Log format: text (engineer mode, default) or json (platform mode)
LOG_FORMAT=text
LOG_LEVEL=INFO

# Service-specific env vars below
# {{SERVICE}}_API_BASE_URL=
# {{SERVICE}}_API_KEY=
